# --- Project Configuration ---
PROJECT_ID=mia-agentic-arch-eval-system
ENVIRONMENT=dev # dev, prod
LOCATION=us-central1

# --- Agentic AI / Vertex AI ---
# Using GCP Vertex AI as the primary "Brain"
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_MODEL_ID=gemini-1.5-pro
ANTHROPIC_API_KEY=your_key_if_using_claude

# --- Data Orchestration (Kafka / Confluent) ---
CONFLUENT_CLOUD_API_KEY=your_api_key
CONFLUENT_CLOUD_API_SECRET=your_api_secret
KAFKA_BOOTSTRAP_SERVER=pkc-xxxx.us-east-1.aws.confluent.cloud:9092

# --- Infrastructure / Cloud ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
TF_VAR_db_password=secure_password_here

# --- Security & Compliance ---
NIST_COMPLIANCE_MODE=true
